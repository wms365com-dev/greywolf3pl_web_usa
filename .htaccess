# Grey Wolf 3PL production config
# Simplified for a static site with PHP form handlers on Bluehost.

DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
RewriteEngine On

# Force the canonical HTTPS + www host.
RewriteCond %{ENV:GW_DISABLE_CANONICAL_REDIRECT} !1
RewriteCond %{HTTP_HOST} !\.railway\.app$ [NC]
RewriteCond %{HTTP_HOST} !^www\.greywolf3pl\.com$ [NC]
RewriteRule ^ https://www.greywolf3pl.com%{REQUEST_URI} [L,R=301]

RewriteCond %{ENV:GW_DISABLE_CANONICAL_REDIRECT} !1
RewriteCond %{HTTP_HOST} !\.railway\.app$ [NC]
RewriteCond %{HTTP_HOST} ^www\.greywolf3pl\.com$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://www.greywolf3pl.com%{REQUEST_URI} [L,R=301]
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresDefault "access plus 24 hours"
ExpiresByType text/html "access plus 2 hours"
ExpiresByType text/css "access plus 24 hours"
ExpiresByType application/javascript "access plus 24 hours"
ExpiresByType image/jpeg "access plus 24 hours"
ExpiresByType image/png "access plus 24 hours"
ExpiresByType image/webp "access plus 24 hours"
ExpiresByType image/svg+xml "access plus 24 hours"
ExpiresByType video/mp4 "access plus 24 hours"
ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
